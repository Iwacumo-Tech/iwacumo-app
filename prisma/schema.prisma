// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  username      String?    @unique
  first_name    String
  last_name     String?
  phone_number  String?
  active        Boolean    @default(true)
  date_of_birth DateTime?
  claims        Claim[]
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  deleted_at    DateTime?
  publisher     Publisher?
  author        Author?
  customers     Customer[]
  tenantMember  Tenant[]   @relation("TenantUsers")
  Review        Review[]
  Cart          Cart[]

  payment_account  PaymentAccount?

  email_verified_at  DateTime?
  verification_tokens VerificationToken[]

  @@map("users")
}

model Claim {
  id            String      @id @default(uuid())
  active        Boolean     @default(true)
  type          String // Possible values: "ROLE", "PERMISSION"
  user_id       String
  permission_id String?
  role_name     String?
  permission    Permission? @relation(fields: [permission_id], references: [id])
  role          Role?       @relation(fields: [role_name], references: [name])
  user          User        @relation(fields: [user_id], references: [id])
  tenant_slug   String?

  @@unique([user_id, role_name], name: "unique_claim_role")
  @@unique([user_id, permission_id], name: "unique_claim_permission")
  @@map(name: "claims")
}

model Permission {
  id          String           @id @default(uuid())
  name        String
  active      Boolean          @default(true)
  module      String
  action      String
  resource_id String?
  roles       PermissionRole[]
  users       Claim[]

  @@unique(name: "unique_permission", [resource_id, action, module])
  @@map(name: "permissions")
}

model Role {
  name            String           @id
  active          Boolean          @default(true)
  built_in        Boolean          @default(false)
  description     String?
  scope           String?          // global, publisher
  publisher_id    String?
  publisher       Publisher?       @relation(fields: [publisher_id], references: [id])
  permissions     PermissionRole[]
  users           Claim[]
  admin_users     AdminUserRole[]
  deleted_at      DateTime?

  @@map(name: "roles")
}

model PermissionRole {
  id            String     @id @default(uuid())
  active        Boolean
  role_name     String
  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id])
  role          Role       @relation(fields: [role_name], references: [name])

  @@unique([id, role_name], name: "unique_permission_role")
  @@map(name: "permission_role")
}

model Tenant {
  id            String     @id @default(uuid())
  name          String?
  contact_email String?
  users         User[]     @relation("TenantUsers")
  admin_users   AdminUser[]
  admin_user_roles AdminUserRole[]
  slug          String?    @unique
  publishers    Publisher?
  deleted_at    DateTime?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  // BRANDING FIELDS ---
  custom_domain    String?
  logo_url         String?
  brand_color      String?
  secondary_color  String?
  social_links     Json?
  banners     Banner[]
  hero_slides HeroSlide[]

  tagline          String?
  font_family      String?   // "inter" | "playfair" | "space-grotesk" | "lora"
  store_settings   Json?     // { heroLayout, showCategories, showFeatured, showNewArrivals, accentStyle }


  @@map("tenants")
}

model Publisher {
  id              String          @id @default(uuid())
  custom_domain   String?
  bio             String?
  profile_picture String?
  social_handles  Json?
  user_id         String          @unique
  user            User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant_id       String?         @unique
  tenant          Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customers       Customer[]
  slug            String?         @unique
  deleted_at      DateTime?
  authors         Author[]
  books           Book[]
  orders          Order[]
  author_splits   PublisherAuthorSplit[]
  admin_user_roles AdminUserRole[]
  roles           Role[]
  white_label     Boolean         @default(false)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  kyc  KycVerification?

  @@map("publishers")
}

model PublisherAuthorSplit {
  id                      String    @id @default(uuid())
  publisher_id            String
  publisher               Publisher @relation(fields: [publisher_id], references: [id], onDelete: Cascade)
  author_id               String
  author                  Author    @relation(fields: [author_id], references: [id], onDelete: Cascade)
  publisher_split_percent Float     // 0–100 — publisher's % of post-fee remainder
  notes                   String?   // optional memo (e.g. "per contract dated Jan 2026")
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  @@unique([publisher_id, author_id])
  @@map("publisher_author_splits")
}


model Author {
  id              String     @id @default(uuid())
  name            String?
  bio             String?
  profile_picture String?
  social_handles  Json?
  user_id         String     @unique
  user            User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  publisher_id    String?
  slug            String?    @unique
  publisher       Publisher? @relation(fields: [publisher_id], references: [id])
  publisher_splits PublisherAuthorSplit[]
  books           Book[]
  primary_books   Book[]     @relation("PrimaryAuthor")
  customers       Customer[]
  deleted_at      DateTime?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  @@map("authors")
}

model Customer {
  id              String     @id @default(uuid())
  name            String?
  user_id         String     // Removed @unique
  user            User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  purchased_books Book[]     @relation("PurchasedBooks")
  author_id       String?
  author          Author?    @relation(fields: [author_id], references: [id])
  slug            String?    
  
  publisher_id    String?
  publisher       Publisher? @relation(fields: [publisher_id], references: [id])
  orders          Order[]
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  deleted_at      DateTime?

  // A user is unique TO A PUBLISHER
  @@unique([user_id, publisher_id])
  @@map("customers")
}

model Book {
  id                String        @id @default(uuid())
  title             String
  subtitle          String?
  slug              String?       @unique
  description       String?
  synopsis          String?
  cover_image_url   String?
  genre             String?
  subject_tags      String[]
  edition           String?
  publication_date  DateTime?
  default_language  String        @default("en")
  page_count        Int?
  reading_age_min   Int?
  reading_age_max   Int?
  status            String        @default("draft") // draft, pending_review, published, archived
  short_description String?
  long_description  String?
  price             Float
  book_cover        String?
  published         Boolean       @default(false)
  book_cover2       String?
  book_cover3       String?
  book_cover4       String?
  tags              String[]
  categories        Category[]    @relation("BookToCategory")
  paper_back        Boolean       @default(false)
  e_copy            Boolean       @default(false)
  hard_cover        Boolean       @default(false)
  pdf_url           String?
  text_url          String?
  publisher_id      String?
  featured          Boolean       @default(false) @map("featured_global") // Master switch for Landing Page
  featured_shop     Boolean       @default(false)                         // Switch for Publisher's Storefront
  primary_author_id String?
  primary_author    Author?       @relation("PrimaryAuthor", fields: [primary_author_id], references: [id])
  metadata          Json?
  chapters          Chapter[]
  variants          BookVariant[]
  publisher         Publisher?    @relation(fields: [publisher_id], references: [id])
  author_id         String?
  author            Author?        @relation(fields: [author_id], references: [id])
  purchased_by      Customer[]    @relation("PurchasedBooks")
  reviews           Review[]

  split_override  BookSplitOverride?

  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  published_at      DateTime?
  archived_at       DateTime?
  deleted_at        DateTime?

  @@map("books")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?  // For dashboard/navigation icons
  books       Book[]   @relation("BookToCategory")
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("categories")
}

model BookVariant {
  id                String    @id @default(uuid())
  book_id           String
  book              Book      @relation(fields: [book_id], references: [id], onDelete: Cascade)
  format            String    // hardcover, paperback, ebook, audiobook, etc.
  size              String?   // A5, A4, A6 (for physical books only)
  isbn13            String?   @unique
  language          String    @default("en")
  list_price        Float
  currency          String    @default("USD")
  discount_price    Float?
  stock_quantity    Int       @default(0)
  sku               String?   @unique
  digital_asset_url String?
  weight_grams      Int?
  dimensions        Json?     // {width, height, depth}
  status            String    @default("active") // active, inactive, archived
  order_lineitems   OrderLineItem[]
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("book_variants")
}

model BookSplitOverride {
  id                      String   @id @default(uuid())
  book_id                 String   @unique
  book                    Book     @relation(fields: [book_id], references: [id], onDelete: Cascade)
  publisher_split_percent Float    // 0–100 — publisher's % of post-fee remainder
  notes                   String?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@map("book_split_overrides")
}

model PaymentAccount {
  id                       String    @id @default(uuid())
  user_id                  String    @unique
  user                     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  bank_name                String
  bank_code                String    // Paystack bank code, e.g. "058"
  account_number           String
  account_name             String    // resolved by Paystack /bank/resolve

  // Paystack identifiers — set after successful subaccount/recipient creation
  paystack_subaccount_code String?   @unique  // e.g. "ACCT_xxxxxxxxxx" — for split payments
  paystack_recipient_code  String?   @unique  // e.g. "RCP_xxxxxxxxxx"  — for manual transfers

  is_verified              Boolean   @default(false)
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  @@map("payment_accounts")
}


model Cart {
  id         String    @id @default(uuid())
  book_image String
  book_title String
  book_type  String
  price      Float
  quantity   Int?
  total      Float
  user       User?     @relation(fields: [userId], references: [id])
  userId     String?
  deleted_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
}

model Review {
  id         String    @id @default(uuid())
  rating     Int
  comment    String
  book_id    String
  user_id    String
  name       String?
  email      String?
  book       Book      @relation(fields: [book_id], references: [id])
  user       User      @relation(fields: [user_id], references: [id])
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@map("reviews")
}

model Chapter {
  id             String         @id @default(uuid())
  title          String
  sub_title      String?
  content        String
  summary        String?
  chapter_number Int
  word_count     Int            @default(0)
  chapter_images ChapterImage[]
  book_id        String?
  book           Book?          @relation(fields: [book_id], references: [id])
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  deleted_at     DateTime?

  @@map("chapters")
}

model ChapterImage {
  id         String    @id @default(uuid())
  image_url  String
  position   Int
  caption    String?
  chapter_id String
  chapter    Chapter   @relation(fields: [chapter_id], references: [id])
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@map("chapter_images")
}

model HeroSlide {
  id          Int       @id @default(autoincrement())
  title       String
  subtitle    String
  description String
  image       String
  buttonText  String
  buttonRoute String

  tenant_id   String?   // Null means Global
  tenant      Tenant?   @relation(fields: [tenant_id], references: [id])

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  @@map("hero_slide")
}

model Banner {
  id         String    @id @default(uuid())
  image      String
  isShow     Boolean   @default(true)

  tenant_id   String?   // Null means it's a "Global" banner
  tenant      Tenant?   @relation(fields: [tenant_id], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deleted_at DateTime?

  @@map("banner")
}

model Order {
  id                  String            @id @default(uuid())
  order_number        String            @unique
  customer_id         String
  customer            Customer          @relation(fields: [customer_id], references: [id])
  publisher_id        String?
  publisher           Publisher?        @relation(fields: [publisher_id], references: [id])
  total_amount        Float
  currency            String            @default("USD")
  subtotal_amount     Float
  tax_amount          Float             @default(0)
  shipping_amount     Float             @default(0)
  discount_amount     Float             @default(0)
  status              String            @default("draft") // draft, pending, paid, fulfilled, cancelled, refunded
  payment_status      String            @default("pending") // pending, authorized, captured, refunded, failed
  channel             String?           // web, mobile, wholesale, etc.
  notes               String?
  shipping_address_id String?
  billing_address_id  String?
  line_items          OrderLineItem[]
  transactions        TransactionHistory[]
  deliveries          DeliveryTracking[]
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  @@map("orders")
}

model OrderLineItem {
  id                  String            @id @default(uuid())
  order_id            String
  order               Order             @relation(fields: [order_id], references: [id], onDelete: Cascade)
  book_variant_id     String
  book_variant        BookVariant       @relation(fields: [book_variant_id], references: [id])
  quantity            Int
  unit_price          Float
  currency            String            @default("USD")
  total_price         Float

  platform_fee        Float              @default(0)
  publisher_earnings  Float              @default(0)
  author_earnings     Float              @default(0)

  fulfillment_status  String            @default("unfulfilled") // unfulfilled, in_progress, shipped, delivered, cancelled
  metadata            Json?
  deliveries          DeliveryTracking[]
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  @@map("order_lineitems")
}

model TransactionHistory {
  id                    String    @id @default(uuid())
  order_id              String
  order                 Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)
  type                  String    // authorization, capture, refund, payout, chargeback
  amount                Float
  currency              String     @default("USD")
  payment_provider      String?    // Stripe, PayPal, etc.
  provider_reference    String?
  status                String     @default("pending") // pending, succeeded, failed
  processor_response    Json?
  recorded_by_admin_id  String?
  recorded_by_admin     AdminUser? @relation(fields: [recorded_by_admin_id], references: [id])
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  @@map("transaction_history")
}

model DeliveryTracking {
  id                  String          @id @default(uuid())
  order_id            String
  order               Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  order_lineitem_id   String?
  order_lineitem      OrderLineItem?   @relation(fields: [order_lineitem_id], references: [id])
  carrier             String
  service_level       String?          // standard, express, overnight, etc.
  tracking_number     String          @unique
  tracking_url        String?
  estimated_delivery_at DateTime?
  shipped_at          DateTime?
  delivered_at        DateTime?
  status              String           @default("pending") // pending, in_transit, out_for_delivery, delivered, delayed, failed
  proof_of_delivery   Json?
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  @@map("delivery_tracking")
}

model AdminUser {
  id            String            @id @default(uuid())
  tenant_id     String            // Required: AdminUser belongs to a Tenant/Organization
  tenant        Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  email         String            @unique
  password_hash String?
  first_name    String?
  last_name     String?
  status        String            @default("invited") // invited, active, suspended, archived
  last_login_at DateTime?
  roles         AdminUserRole[]
  transactions  TransactionHistory[]
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  
  email_verified_at  DateTime?

  verification_tokens VerificationToken[]
  kyc_reviews KycVerification[]

  @@map("admin_users")
}

model AdminUserRole {
  id            String    @id @default(uuid())
  admin_user_id String
  admin_user    AdminUser @relation(fields: [admin_user_id], references: [id], onDelete: Cascade)
  tenant_id     String    // Required: AdminUserRole belongs to a Tenant
  tenant        Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  role_name     String
  role          Role      @relation(fields: [role_name], references: [name], onDelete: Cascade)
  publisher_id  String?
  publisher     Publisher? @relation(fields: [publisher_id], references: [id])
  expires_at    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@unique([admin_user_id, role_name, publisher_id, tenant_id])
  @@map("admin_user_roles")
}

model SystemSettings {
  id                    String   @id @default(uuid())
  key                  String   @unique
  value                Json
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@map("system_settings")
}


model VerificationToken {
  id             String     @id @default(uuid())
  token          String     @unique
  user_id        String?                              // nullable — for User tokens
  user           User?      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  admin_user_id  String?                              // nullable — for AdminUser tokens
  admin_user     AdminUser? @relation(fields: [admin_user_id], references: [id], onDelete: Cascade)
  type           String
  expires_at     DateTime
  used_at        DateTime?
  created_at     DateTime   @default(now())

  @@map("verification_tokens")
}


model KycVerification {
  id           String    @id @default(uuid())
  publisher_id String    @unique
  publisher    Publisher @relation(fields: [publisher_id], references: [id], onDelete: Cascade)

  // Status lifecycle: pending → submitted → approved | rejected
  status       String    @default("pending")

  // Identity document
  id_document_url  String?
  id_document_type String? // "passport" | "national_id" | "drivers_license"
  legal_name       String?
  phone_number     String?

  // Business registration
  business_reg_url  String?
  business_name     String?
  business_address  String?

  // Proof of address
  proof_of_address_url String?

  // Admin review
  submitted_at   DateTime?
  reviewed_at    DateTime?
  reviewer_id    String?
  reviewer       AdminUser? @relation(fields: [reviewer_id], references: [id])
  reviewer_notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("kyc_verifications")
}
